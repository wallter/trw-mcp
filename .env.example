# TRW MCP Server — Environment Variables
# All settings use TRW_ prefix (case-insensitive via pydantic-settings).
# Copy to .env and uncomment/fill values as needed.

# ── Project Root ───────────────────────────────────────────────────────────
# Auto-detected from cwd if not set
# TRW_PROJECT_ROOT=/path/to/project

# ── Debug Mode ─────────────────────────────────────────────────────────────
TRW_DEBUG=false

# ── Agent Identity (for telemetry) ────────────────────────────────────────
TRW_AGENT_ID=default
TRW_AGENT_ROLE=lead

# ── Ceremony Scoring ──────────────────────────────────────────────────────
# TRW_CEREMONY_WEIGHT=0.5
# TRW_QUALITY_WEIGHT=0.3
# TRW_VELOCITY_WEIGHT=0.2

# ── Build Verification ────────────────────────────────────────────────────
# TRW_BUILD_CHECK_ENABLED=true
# TRW_BUILD_CHECK_COVERAGE_MIN=85.0
# TRW_BUILD_GATE_ENFORCEMENT=lenient

# ── Platform Telemetry (opt-in) ───────────────────────────────────────────
# TRW_PLATFORM_URL=https://api.trwframework.com
# TRW_PLATFORM_TELEMETRY_ENABLED=false
# TRW_INSTALLATION_ID=
